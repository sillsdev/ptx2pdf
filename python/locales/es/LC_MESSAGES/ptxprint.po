msgid "PARATEXT: Make a copy of the Project's FRT book\n"
"(which may be edited to make use of \\zvar|variables\\*)"
msgstr ""

#: temp.glade:2646
msgid "Generate front matter: PARATEXT (make a local copy)"
msgstr "Generar las páginas iniciales: PARATEXT (hacer una copia local)"

#: temp.glade:2650
