msgid "Set the color to use when\n"
"differences are found between\n"
"the old and the new PDFs.\n\n"
"Use this color to show anything\n"
"that has been added (or moved to\n"
"the current location) in the new PDF."
msgstr "Makim kala bilong yusim taim ol i painim narapela narapela samting namel long ol nupela PDF na ol nupela PDF."

#: temp.glade:37901
msgid "Show New Text\n"
"or Position in:"
msgstr "Lukim Nupela Toktok o Ples Long:"

#: temp.glade:37911
msgid "Compare PDFs: Colour of old text"
msgstr "Skelim ol PDF: Kala bilong olpela rait"

#: temp.glade:37914 temp.glade:38018
msgid "Set the color to use when\n"
"differences are found between\n"
"the old and the new PDFs.\n\n"
"Use this color to show anything\n"
"that has been deleted (or moved from\n"
"the previous location) in the old PDF."
msgstr "Makim kala bilong yusim taim ol i painim narapela narapela samting namel long ol nupela PDF na olpela PDF."

#: temp.glade:37924
msgid "Show Old Text\n"
"or Position in:"
msgstr "Lukim Olpela Toktok o Ples Long:"

#: temp.glade:37937
msgid "Use this color to show anything\n"
"that has been deleted (or moved from\n"
"the previous location) in the old PDF."
msgstr "Yu ken yusim dispela kala bilong soim ol samting yu bin rausim (o rausim long ples bipo) long ol PDF bilong bipo."

#: temp.glade:37958
msgid "Select a particular PDF file to be compared \n"
"against the current output PDF. If you just \n"
"want to compare output to the previous run,\n"
"then click Cancel in the File Open dialog\n"
"to reset the filename (which will then\n"
"default to _1)."
msgstr "Makim wanpela PDF file yu laik skelim wantaim dispela output PDF. Sapos yu laik skelim output wantaim dispela output bipo, klik Kansela long Open File dialog na putim gen nem bilong dispela file (olsem default bai _1)."

#: temp.glade:37966
msgid "Compare With \n"
"a Previous PDF:"
msgstr "Skelim wantaim PDF i stap bipo:"

#: temp.glade:37979
msgid "Compare PDFs: Set maximum diff pages to show"
msgstr "Skelim ol PDF: Makim bikpela mak bilong ol narapela narapela pes bilong soim"

