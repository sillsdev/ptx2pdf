msgstr "Pas d'espace supérieur"

#: lib/ptxprint/texpert.py:49
msgid "Don’t insert space above headings at the start of a column"
msgstr "Ne pas insérer d'espace au-dessus des en-têtes au début d'une colonne"

#: lib/ptxprint/texpert.py:50
msgid "Suppress pagebreak after bookend-final"
msgstr "Supprimer le saut de page après le bookend-final (fin de livre)"

#: lib/ptxprint/texpert.py:51
msgid "Revert to old behaviour of not ensuring that the whole of the last book is output before back-matter PDFs"
msgstr "Revenir à l'ancien comportement de ne pas s'assurer que l'ensemble du dernier livre est affiché avant les PDFs des annexes"

#: lib/ptxprint/texpert.py:52
msgid "Noteline offset (mm)"
msgstr "Décalage des lignes de notes (mm)"

#: lib/ptxprint/texpert.py:53
msgid "Gap (mm) between noteline and text"
msgstr "Espace (mm) entre les lignes de notes et le texte"

#: lib/ptxprint/texpert.py:54
msgid "Noteline margin (mm)"
msgstr "Marge des lignes de notes (mm)"

#: lib/ptxprint/texpert.py:55
msgid "Gap (mm) between noteline and edge of page"
msgstr "Espace (mm) entre les lignes de notes et le bord de la page"

#: lib/ptxprint/texpert.py:57 lib/ptxprint/texpert.py:115
#: lib/ptxprint/texpert.py:118
msgid "Solid line"
msgstr "Ligne solide"

#: lib/ptxprint/texpert.py:57 lib/ptxprint/texpert.py:115
#: lib/ptxprint/texpert.py:118
msgid "Row of dots"
msgstr "Ligne de points"

#: lib/ptxprint/texpert.py:58
msgid "Noteline type"
msgstr "Type de ligne de note"

#: lib/ptxprint/texpert.py:58
msgid "Sometimes it is preferable to use a series of dots rather than a solid line."
msgstr "Parfois, il est préférable d'utiliser une série de points plutôt qu'une ligne solide."

#: lib/ptxprint/texpert.py:59
msgid "Noteline spacing (mm)"
msgstr "Espacement des lignes de notes (mm)"

#: lib/ptxprint/texpert.py:60
msgid "Line spacing between notelines. When set to 0.00 the default line spacing of the document is used."
msgstr "Interligne entre les lignes des notes. Lorsqu'il est fixé à 0.00, l'interligne par défaut du document est utilisé."

#: lib/ptxprint/texpert.py:61
msgid "Noteline width (major)"
msgstr "Largeur des lignes de notes (majeure)"

#: lib/ptxprint/texpert.py:62
msgid "Thickness (pt) of major notelines. Specify the colour on the Layout page."
msgstr "Épaisseur (pt) des principales lignes de notes. Spécifier la couleur sur la page Mise en page."

#: lib/ptxprint/texpert.py:68
msgid "Double Sided Layout"
msgstr "Mise en page recto-verso"

#: lib/ptxprint/texpert.py:69
msgid "This setting can be disabled to turn off inner/outer margins, forcing the inner/outer gutter, and Notelines to always appear on the same side of the printed page."
msgstr "Désactiver ce paramètre pour désactiver les marges intérieures/extérieures, forçant ainsi la gouttière intérieure/extérieure et les lignes de notes à toujours apparaître du même côté de la page imprimée."

#: lib/ptxprint/texpert.py:71
msgid "Maximum parallel processes"
msgstr ""

#: lib/ptxprint/texpert.py:72
msgid "The maximum number of parallel processes to use for example when page filling"
msgstr ""

#: lib/ptxprint/texpert.py:73
msgid "Maximum Filling Time (mins)"
msgstr ""

#: lib/ptxprint/texpert.py:74
msgid "Stop page filling a book after this many minutes"
msgstr ""

#: lib/ptxprint/texpert.py:78
msgid "Always down"
msgstr ""

#: lib/ptxprint/texpert.py:78
msgid "Always up"
msgstr ""

#: lib/ptxprint/texpert.py:78
msgid "Up on left"
msgstr ""

#: lib/ptxprint/texpert.py:78
msgid "Up on right"
msgstr ""

#: lib/ptxprint/texpert.py:78
msgid "No hyphens"
msgstr ""

#: lib/ptxprint/texpert.py:78
msgid "Position of marginal verse hyphen if any"
msgstr ""

#: lib/ptxprint/texpert.py:78
msgid "Insert or not a marginal verse hyphen in verse ranges, whether on the first or second line"
msgstr ""

#: lib/ptxprint/texpert.py:79
msgid "Gutter space reduction for marginal verses"
msgstr "Réduction de l'espace de la gouttière pour les versets marginaux"

#: lib/ptxprint/texpert.py:79
msgid "If false, the space for marginal verses is taken from the column. If true, some space for marginal verses is taken from the margins or rule gutter"
msgstr "Si faux, l'espace pour les versets marginaux est pris dans la colonne. Si vrai, un peu d'espace pour les versets marginaux est pris dans les marges ou la gouttière de la règle."

#: lib/ptxprint/texpert.py:80
msgid "Auto Calc Optimum Chapter Size"
msgstr "Calcul automatique de la taille optimale du chapitre"

#: lib/ptxprint/texpert.py:81
msgid "Attempt to automatically calculate drop chapter number size"
msgstr "Tenter de calculer automatiquement la taille du grand numéro de chapitre"

#: lib/ptxprint/texpert.py:82
msgid "Don't hang verse one beside a chapter (in poetry)"
msgstr "Ne pas suspendre le verset un à côté d'un chapitre (en poésie)"

#: lib/ptxprint/texpert.py:83
msgid "Hanging verses into a chapter number can result in clashes, depending on the after-chapter space. If so, then turn off hanging verse numbers for the first verse (in poetry only). "
msgstr "Suspendre les versets dans un numéro de chapitre peut entraîner un chevauchement de caractères, selon l'espace de l'après-chapitre. Dans ce cas, désactivez les numéros de versets suspendus pour le premier verset (en poésie seulement)."

#: lib/ptxprint/texpert.py:84
msgid "Alternate verse numbers also hang"
msgstr "Les numéros de versets alternatifs sont également suspendus"

#: lib/ptxprint/texpert.py:85
msgid "If there is an alternative verse and the current verse is hanging, does the alternate hang?"
msgstr "S'il y a un verset alternatif et le verset actuel est suspendu, l'alternatif est-il suspendu ?"

#: lib/ptxprint/texpert.py:86
msgid "After chapter space factor"
msgstr "Après le chapitre Facteur espace"

#: lib/ptxprint/texpert.py:87
msgid "This sets the gap between the chapter number and the text following. The setting here is a multiple of the main body text size as specified in layout."
msgstr "Ce paramètre définit l'écart entre le numéro de chapitre et le texte qui le suit. Ce paramètre est un multiple de la taille du texte du corps principal telle que spécifiée dans la mise en page."

#: lib/ptxprint/texpert.py:89
msgid "After verse space factor"
msgstr "Facteur d'espace après le verset"

#: lib/ptxprint/texpert.py:90
msgid "This sets the gap between the verse number and the text following. The setting here is a multiple of the main body text size as specified in layout."
msgstr "Ce paramètre définit l'écart entre le numéro de verset et le texte qui suit. Ce paramètre est un multiple de la taille du texte du corps principal, telle que spécifiée dans la mise en page."

#: lib/ptxprint/texpert.py:93
msgid "Allow Indent Para with Cutouts"
msgstr "Autoriser le retrait des paragraphes avec les découpes"

#: lib/ptxprint/texpert.py:94
msgid "Allow indented paragraphs at chapter start with cutouts"
msgstr "Autoriser les paragraphes en retrait en début de chapitre avec des découpes"

#: lib/ptxprint/texpert.py:95
msgid "Allow Indent Para After Heading"
msgstr "Autoriser le retrait du paragraphe après l'en-tête"

#: lib/ptxprint/texpert.py:96
msgid "Allow indented paragraphs following a heading"
msgstr "Autoriser les paragraphes en retrait après un en-tête"

#: lib/ptxprint/texpert.py:97
msgid "Maximum orphan word length"
msgstr "Longueur maximale du mot orphelin"

#: lib/ptxprint/texpert.py:98
msgid "Maximum length of the word that will receive orphan protection at the end of a paragraph"
msgstr "Longueur maximale du mot qui bénéficiera de la protection des orphelins à la fin d'un paragraphe"

#: lib/ptxprint/texpert.py:99
msgid "Bad space penalty"
msgstr "Pénalité pour mauvais espace"

#: lib/ptxprint/texpert.py:100
msgid "Penalty for a bad (but not impossible) place to break"
msgstr "Pénalité pour un mauvais (mais pas impossible) endroit pour casser"

#: lib/ptxprint/texpert.py:101
msgid "Optional break penalty"
msgstr "Pénalité facultative de coupure"

#: lib/ptxprint/texpert.py:102
msgid "Penalty for the optional break"
msgstr "Pénalité pour la coupure de ligne facultative"

#: lib/ptxprint/texpert.py:103
msgid "Hyphenation threshold"
msgstr "Limite de césure"

#: lib/ptxprint/texpert.py:104
msgid "Paragraph badness threshold before trying hyphenation. Set to -1 to always hyphenate"
msgstr "Limite de mauvaise qualité d'un paragraphe avant d'essayer la césure. Fixer à -1 pour toujours utiliser le trait d'union"

#: lib/ptxprint/texpert.py:105
msgid "Penalty for inserting hyphen"
msgstr "Pénalité pour l'insertion d'un trait d'union"

#: lib/ptxprint/texpert.py:106
msgid "Hyphenation penalty"
msgstr "Pénalité pour césure"

#: lib/ptxprint/texpert.py:107
msgid "Double hyphenation penalty"
msgstr "Pénalité pour césure doublée"

#: lib/ptxprint/texpert.py:108
msgid "Penalty for consecutive hyphenation across two lines"
msgstr "Pénalité pour césure consécutive sur deux lignes"

#: lib/ptxprint/texpert.py:110
msgid "Use loc attrib on ref to make a link"
msgstr "Utiliser l'attribut loc sur la référence pour créer un lien"

#: lib/ptxprint/texpert.py:111
msgid "The ref character style can include an attribute like loc=\"GEN 1:2\". Should this be used to make a clickable link?"
msgstr "Le style de caractère ref peut inclure un attribut tel que loc=\"GEN 1:2\". Doit-on l'utiliser pour créer un lien cliquable ?"

#: lib/ptxprint/texpert.py:112
msgid "Use href-link attrib on jmp to make a link"
msgstr "Utiliser l'attribut href-link sur jmp pour créer un lien"

#: lib/ptxprint/texpert.py:113
msgid "The jmp character style can include an attribute like href-link=\"https://my.web.site/\". Should this be used to make a clickable link?"
msgstr "Le style de caractère jmp peut inclure un attribut tel que href-link=\"https://my.web.site/\". Doit-on l'utiliser pour créer un lien cliquable ?"

#: lib/ptxprint/texpert.py:115 lib/ptxprint/texpert.py:118
msgid "Underline only"
msgstr "Souligné seulement"

#: lib/ptxprint/texpert.py:115 lib/ptxprint/texpert.py:118
msgid "No line"
msgstr "Aucune ligne"

#: lib/ptxprint/texpert.py:115 lib/ptxprint/texpert.py:118
msgid "Dashed line"
msgstr "Ligne pointillée"

#: lib/ptxprint/texpert.py:115 lib/ptxprint/texpert.py:118
msgid "Viewer default"
msgstr "Visualiseur par défaut"

#: lib/ptxprint/texpert.py:116
msgid "Box style for URL links"
msgstr "Style de boîte pour les liens URL"

#: lib/ptxprint/texpert.py:116
msgid "Active web links in PDFs are marked by either a box (solid, dashed or dotted line) or an underline. Your viewer probably has a default setting. Set the colour with \\def\\URLLinkBorderCol{0.9 0.5 0.5} or similar in ptxprint-mods.tex."
msgstr "Les liens web actifs dans les PDF sont marqués par un cadre (ligne pleine ou pointillée) ou un trait de soulignement. Votre logiciel de visualisation dispose probablement d'un réglage par défaut. Définissez la couleur avec \\def\\URLLinkBorderCol{0.9 0.5 0.5} ou similaire dans ptxprint-mods.tex."

#: lib/ptxprint/texpert.py:119
msgid "Box style for GOTO links"
msgstr "Style de boîte pour les liens GOTO"

#: lib/ptxprint/texpert.py:119
msgid "Active internal links in PDFs are marked by either a box (solid, dashed or dotted line) or an underline. Your viewer probably has a default setting. Set the colour with \\def\\GOTOLinkBorderCol{0.9 0.5 0.5} or similar in ptxprint-mods.tex."
msgstr "Les liens web actifs en PDF sont marqués soit par une case (ligne solide ou pointillée) soit par un soulignement. Votre visualiseur a probablement un paramètre par défaut. Définissez la couleur avec \\def\\GOTOLinkBorderCol{0.9 0.5 0.5} ou similaire dans ptxprint-mods.tex."

#: lib/ptxprint/texpert.py:120
msgid "Use glyph metrics"
msgstr "Utiliser les métriques de glyphe"

#: lib/ptxprint/texpert.py:121
msgid "PTXprint can use either the actual glyph metrics in a line or the font metrics to calculate line heights and depths. Font metrics gives more consistent results."
msgstr "PTXprint peut utiliser soit la métrique réelle des glyphes dans une ligne, soit la métrique de la police pour calculer la hauteur et la profondeur des lignes. Les métriques de police donnent des résultats plus cohérents."

#: lib/ptxprint/texpert.py:123
msgid "Use system fonts"
msgstr "Utiliser les polices du système"

#: lib/ptxprint/texpert.py:124
msgid "Use fonts from your system as well as your project. Note that you need to restart PTXprint for this setting to take effect."
msgstr "Utilisez les polices de votre système ainsi que votre projet. Notez que vous devez redémarrer PTXprint pour que ce paramètre prenne effet."

#: lib/ptxprint/texpert.py:125
msgid "Underline thickness (em)"
msgstr "Epaisseur du soulignement (em)"

#: lib/ptxprint/texpert.py:126
msgid "This sets the thickness of the text underline, (measured in ems)."
msgstr "Ce paramètre définit l'épaisseur du soulignement du texte (mesurée en ems)."

#: lib/ptxprint/texpert.py:128
msgid "Underline vertical position (em)"
msgstr "Position verticale du soulignement (em)"

#: lib/ptxprint/texpert.py:129
msgid "This sets how far (in ems) the underline is below the text and what it is relative to. If negative, it is the distance below the baseline. If positive (or zero), it is the distance below the bottom of any descenders."
msgstr "Ce paramètre définit la distance (en ems) à laquelle le soulignement se trouve sous le texte et ce à quoi il se rapporte. Si elle est négative, il s'agit de la distance sous la ligne de base. Si elle est positive (ou nulle), il s'agit de la distance en dessous du bas de tout descendant."

#: lib/ptxprint/texpert.py:131
msgid "Underline Spaces"
msgstr "Souligner les espaces"

#: lib/ptxprint/texpert.py:132
msgid "Underline spaces in underlined runs"
msgstr "Souligner les espaces dans les passages soulignés"

#: lib/ptxprint/texpert.py:133
msgid "Log font creation"
msgstr ""

#: lib/ptxprint/texpert.py:134
msgid "Create <jobname>.fontusage in the local/ptxprint/<config>/ directory, which will list the page number and exact font definition when each new style is first used."
msgstr ""

#: lib/ptxprint/texpert.py:136
msgid "Mid-Page Footnotes"
msgstr "Notes de bas de page en milieu de page"

#: lib/ptxprint/texpert.py:137
msgid "Should footnotes go before a single-double column transition"
msgstr "Les notes de bas de page doivent-elles précéder une transition en colonne simple-double"

#: lib/ptxprint/texpert.py:138
msgid "Final Page Notes Down"
msgstr "Notes de la page finale en bas"

#: lib/ptxprint/texpert.py:139
msgid "Push notes on the final page to the bottom of the page"
msgstr "Pousser les notes de la dernière page vers le bas de la page"

#: lib/ptxprint/texpert.py:140
msgid "Reset Callers at Each Book"
msgstr "Réinitialiser les appelants à chaque livre"

#: lib/ptxprint/texpert.py:141
msgid "Re-start the footnote and cross-reference callers at the start of each book"
msgstr "Redémarrer la séquence des appelants de note de bas de page et de référence croisée au début de chaque livre"

#: lib/ptxprint/texpert.py:142
msgid "Endnotes at Each Book"
msgstr "Notes de fin de chapitre pour chaque livre"

#: lib/ptxprint/texpert.py:143
msgid "Output endnotes at the end of each book"
msgstr "Publier les notes à la fin de chaque livre"

#: lib/ptxprint/texpert.py:144
msgid "Enhanced paragraphed footnotes"
msgstr "Notes de bas de page en paragraphe améliorées"

#: lib/ptxprint/texpert.py:145
msgid "Paragraphed footnotes which allow \\fp to work and also the ifparnotes... controls below. Causes some spacing differences compared to old-style."
msgstr "Notes de bas de page en paragraphe qui permettent à \\fp de fonctionner et aussi aux contrôles ifparnotes... ci-dessous. Cela entraîne des différences d'espacement par rapport à l'ancien style."

#: lib/ptxprint/texpert.py:146
msgid "Remove depth above paragraphed notes"
msgstr "Supprimer la profondeur au-dessus des notes en paragraphe"

#: lib/ptxprint/texpert.py:147
msgid "Kern away (kill) the glyph/font depth of note types before paragraphed notes, using the value of \\prevdepth"
msgstr "Supprimer la profondeur de glyphe des types de note avant les notes en paragraphe, utilisant la valeur de \\prevdepth"

#: lib/ptxprint/texpert.py:148
msgid "Remove depth after paragraphed notes"
msgstr "Supprimer la profondeur après les notes en paragraphe"

#: lib/ptxprint/texpert.py:149
msgid "Kill the depth of (the last row of) paragraphed note styles. Paragraphed notes will use the margin as their baseline."
msgstr "Supprimer la profondeur (de la dernière ligne) des styles de notes en paragraphe. Les notes en paragraphe utiliseront la marge comme ligne de base."

#: lib/ptxprint/texpert.py:150
msgid "Use grid not font/glyph height at rule"
msgstr "Utiliser la grille et non la hauteur des polices/glyphes à la règle"

#: lib/ptxprint/texpert.py:151
msgid "If true, the footnote rule is positioned relative to the hypothetical baseline above the topmost footnote, rather than relative to the glyph/font height."
msgstr "Si vrai, la règle de la note de bas de page est positionnée par rapport à la ligne de base hypothétique au-dessus de la première note de bas de page, plutôt que relatif à la hauteur du glyphe/fonte."

#: lib/ptxprint/texpert.py:152
msgid "Use grid not font/glyph height between notes"
msgstr "Utiliser la grille et non la hauteur des polices/glyphes entre les notes"

#: lib/ptxprint/texpert.py:153
msgid "If true, then the \\InterNoteSpace is relative to the hypothetical baseline above the topmost footnote, rather than the glyph/font height. \\InterNoteSpace is triggered between note styles."
msgstr "Si vrai, \\InterNoteSpace est relatif à la ligne de base hypothétique au-dessus de la première note de bas de page, plutôt que de la hauteur du glyphe/fonte. \\InterNoteSpace est appliqué entre les styles de notes."

#: lib/ptxprint/texpert.py:154
msgid "Use glyph height not font height in footnotes"
msgstr "Utiliser la hauteur des glyphes et non la hauteur de la police dans les notes de bas de page"

#: lib/ptxprint/texpert.py:155
msgid "Does the note use the font's descender design parameter, or the actual bottom of the glyph. If the former (and depth is not killed), then the bottom of notes have a common baseline across pages. If the latter, then the glyphs sit as close to the bottom margin as they can, which may permit an extra line of text."
msgstr "La note utilise-t-elle le paramètre descendant de la police ou le bas du glyphe. Si la première (et la profondeur n'est pas suppimée), les bas des notes ont une ligne de base commune sur les pages. Dans ce dernier cas, les glyphes s'asseyent aussi près de la marge inférieure qu'ils le peuvent, ce qui peut permettre une ligne de texte supplémentaire."

#: lib/ptxprint/texpert.py:156
msgid "Last Note: interlinepenalty"
msgstr "Dernière note : pénalité d'interligne"

#: lib/ptxprint/texpert.py:157
msgid "Penalty for breaking between lines of the last footnote."
msgstr "Pénalité pour la rupture entre les lignes de la dernière note de bas de page."

#: lib/ptxprint/texpert.py:158
msgid "Last Note: widowpenalty"
msgstr "Dernière note : pénalité pour veuve"

#: lib/ptxprint/texpert.py:159
msgid "Extra penalty for breaking at the last line of the last footnote."
msgstr "Pénalité supplémentaire pour rupture à la dernière ligne de la dernière note de bas de page."

#: lib/ptxprint/texpert.py:160
msgid "Last Note: clubpenalty"
msgstr "Dernière note : pénalité de club"

#: lib/ptxprint/texpert.py:161
msgid "Extra penalty for breaking at the first line of the last footnote."
msgstr "Pénalité supplémentaire pour rupture à la première ligne de la dernière note de bas de page."

#: lib/ptxprint/texpert.py:162
msgid "Last Note: penalty at par"
msgstr "Dernière note : pénalité paragraphe"

#: lib/ptxprint/texpert.py:163
msgid "Penalty for breaking at an explicit footnote-paragraph in the last footnote."
msgstr "Pénalité pour la rupture à un paragraphe de bas de page explicite dans la dernière note de bas de page."

#: lib/ptxprint/texpert.py:164
msgid "Split notes: Shortest note to shave"
msgstr "Notes fractionnées : La note la plus courte à raser"

#: lib/ptxprint/texpert.py:165
msgid "If footnotes might be shaved, how many lines must it be?"
msgstr "Si les notes de bas de page peuvent être rasées, combien de lignes doivent-elles comporter ?"

#: lib/ptxprint/texpert.py:166
msgid "Split notes: min lines to move."
msgstr "Notes fractionnées : lignes minimum à déplacer."

#: lib/ptxprint/texpert.py:167
msgid "If a footnote is being shaved (split onto next page), what is the minimum number of lines to move?"
msgstr "Si une note de bas de page est rasée (divisée avec la page suivante), quel est le nombre minimum de lignes à déplacer ?"

#: lib/ptxprint/texpert.py:168
msgid "Split notes: note lines to stay"
msgstr "Notes fractionnées : lignes minimum à rester"

#: lib/ptxprint/texpert.py:169
msgid "If a footnote is being shaved (split onto next page), how many lines of (all) notes must remain on the page?"
msgstr "Si une note de bas de page est rasée (divisée avec la page suivante), combien de lignes de (toutes) notes doivent rester sur la page ?"

#: lib/ptxprint/texpert.py:170
msgid "Footnote factor-Single column"
msgstr "Facteur de note de bas de page - Colonne unique"

#: lib/ptxprint/texpert.py:171
msgid "To avoid needless cylces/underful pages, what portion of a note's height-estimate should TeX apply when gathering input in single-column mode? (100=10percent)"
msgstr "Pour éviter les pages insuffisamment remplies, quelle portion de l'estimation de la hauteur d'une note doit le système appliquer lorsqu'il recueille des données en mode colonne unique ? (100=10 pour cent)"

#: lib/ptxprint/texpert.py:172
msgid "Footnote factor-Two column"
msgstr "Facteur de note de bas de page - Deux colonnes"

#: lib/ptxprint/texpert.py:173
msgid "To avoid needless cylces/underful pages, what portion of a note's height-estimate should TeX apply when gathering input in two-column mode? (100=10percent)"
msgstr "Pour éviter les pages insuffisamment remplies, quelle portion de l'estimation de la hauteur d'une note doit le système appliquer lorsqu'il recueille des données en mode deux colonnes ? (100=10 pour cent)"

#: lib/ptxprint/texpert.py:174
msgid "Footnote factor-Diglot"
msgstr "Facteur de note de bas de page - Diglot"

#: lib/ptxprint/texpert.py:175
msgid "To avoid needless cylces/underful pages, what portion of a note's height-estimate should TeX apply when gathering diglot input? (100=10percent)"
msgstr "Pour éviter les pages insuffisamment remplies, quelle portion de l'estimation de la hauteur d'une note doit le système appliquer lorsqu'il recueille des données de diglot ? (100=10 pour cent)"

#: lib/ptxprint/texpert.py:176
msgid "Footnote factor-Centre column"
msgstr "Facteur de note de bas de page - Colonne centrale"

#: lib/ptxprint/texpert.py:177
msgid "To avoid needless cylces/underful pages, what portion of a note's height-estimate should TeX apply when gathering centre-column notes? (100=10percent)"
msgstr "Pour éviter les pages insuffisamment remplies, quelle portion de l'estimation de la hauteur d'une note doit le système appliquer lorsqu'il recueille des notes de la colonne centrale ? (100=10 pour cent)"

#: lib/ptxprint/texpert.py:179
msgid "Balance diglot/polyglot notes"
msgstr ""

#: lib/ptxprint/texpert.py:180
msgid "When there's a note on column R (for example), does that reduce the space from other columns?"
msgstr ""

#: lib/ptxprint/texpert.py:181
msgid "Diglot/polyglot merged paragraphed notes are RTL"
msgstr ""

#: lib/ptxprint/texpert.py:182
msgid "When merged notes are not shown as individual paragraphs, the result must be arranged as though RTL or LTR (however the induvidual notes are structured). This defines the paragraph alignment."
msgstr ""

#: lib/ptxprint/texpert.py:183
msgid "Adjust Versification of Projects"
msgstr "Ajuster la Versification des Projets"

#: lib/ptxprint/texpert.py:184
msgid "If versification differs between projects, adjust diglot/polyglot projects to match the primary (L) project."
msgstr "Si la versification diffère d'un projet à l'autre, ajuster les projets diglot/polyglot pour qu'ils correspondent au projet principal (L)."

#: lib/ptxprint/texpert.py:185
msgid "Keep existing verse numbers (as \\vp)"
msgstr "Conserver les numéros de verset existants (comme \\vp)"

#: lib/ptxprint/texpert.py:186
msgid "When adjusting versification, show the original verse numbers in their new (adjusted) location."
msgstr "Lors de l'ajustement de la versification, afficher les numéros de verset d'origine dans leur nouvel emplacement (ajusté)."

#: lib/ptxprint/texpert.py:187
msgid "Show old chapter numbers if changed (in \\vp)"
msgstr "Afficher les anciens numéros de chapitre s'ils ont été modifiés (en \\vp)"

#: lib/ptxprint/texpert.py:188
msgid "When adjusting versification, show the adjusted chapter numbers (only) if they have changed."
