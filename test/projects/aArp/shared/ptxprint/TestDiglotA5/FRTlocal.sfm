\periph front|id="coverfront"
\zgap|15pt\*
\mt1 \zvar|t1title\*
\mt2 \zvar|t2title\*
\rem zgap|10pt\*
\fig |src="C:\0PTXCoverPix\CN01840B.png" size="col" pgpos="pc" scale="0.50" copy="None"\fig*
\zgap|10pt\*
\mt3 \zvar|t1languagelocalspelling\* \zvar|t1andinlocallanguage\* \zvar|t2languagelocalspelling\*
\endgraf
\periph spine|id="coverspine"
\mt2 \zvar|t1title\* ~~-~~ \zvar|t2title\*
\p
\periph back|id="coverback"
\zgap|1in\*
\pc ~
\vfill
\zifvarset|var="isbn" emptyok="F"\*
\ztruetext
\esb \cat ISBNbox\cat* \pc \zISBNbarcode|var="isbn" height="medium"\* \esbe
\zgap|10pt\*
\ztruetext*
\periph spannedCover|id="coverwhole"
\zgap|1pt\*
\vfill
\pc ~
\vfill
\endgraf
\periph Title Page|id="title"
\rem -------------------------------------------------------------------------
\mt1
\nopagenums
\zbl|4\*
\mt1 \zvar|t1title\*
\mt2 \zvar|t2title\*
\fig |src="C:\0PTXCoverPix\CN01840B.png" size="col" pgpos="pc" scale="0.50" copy="None"\fig*

\rem -------------------------------------------------------------------------
\periph Publication Data|id="pubdata"
\rem -------------------------------------------------------------------------
\zglot|L\*
\zgap|0.5in\*
\mt1 \zvar|t1title\*
\mt2 \zvar|t2title\*
\zbl|1\*
\pc This diglot publication includes a translation of \zvar|englishbooknames\* into the \zvar|languagename\* language. The opposite side of the diglot is a translation of the \zvar|languagename\* text into Melanesian Pidgin (Tok Pisin).
\zbl|1\*
\pc Printed by Aitape West Translation Project, //Arop Village, Sandaun Province, Papua New Guinea
\pc Copies printed: \zvar|copiesprinted\*
\pc Date printed: \zvar|dateprinted\*
\pc \zvar|edition\* Edition, \zvar|printing\* Printing
\zbl|1\*
\pc \zcopyright
\zccimg by-nc-nd|size="col" pgpos="pc" scale="0.25"\*
\zgap|3pt\*
\pc \zimagecopyrights
\pc All uncredited pictures are in the public domain.

\rem -------------------------------------------------------------------------
\periph Table of Contents|id="contents"
\rem -------------------------------------------------------------------------
\mt
\zbl|3\*
\mt3 \zvar|t1contentstitle\*
\zgap|6pt\*
\ip \ztoc|mainL\*
\zbl|3\*
\mt3 \zvar|t2contentstitle\*
\zgap|6pt\*
\ip \ztoc|mainR\*

\rem -----------------------------------------------------------------------
\periph Transfer Primer|id="transferprimer"
\rem -----------------------------------------------------------------------
\zNeedOddPage
\resetpagenums -1
\dopagenums
\rem next line means we are talking about the T1=L side of the diglot 
\zglot|L\*
\rem next line means go get the periph called "transferprimer"
\zgetperiph|side="L" id="transferprimer"\*
\pagebreak
\rem The next line never gets removed in diglots
\zglot|\*

\rem -------------------------------------------------------------------------
\periph Inline Prefaces|id="prefaces"
\rem -------------------------------------------------------------------------
\zNeedOddPage
\rem we don't do this if we do the Transfer Primer 
\rem \resetpagenums -1
\dopagenums
\rem Prefaces are pulled in from the T1=L and T2=R INT books using periph
\zglot|L\*
\zgetperiph|side="L" id="preface"\*
\pagebreak
\zglot|R\*
\zgetperiph|side="R" id="preface"\*
\rem The next line never gets removed in diglots
\zglot|\*

\rem -----------------------------------------
\periph Tables of Abbreviations|id="abbrlists"
\rem -----------------------------------------
\zNeedOddPage
\dopagenums
\rem Abbreviations tables are pulled in from the T1=L and T2=R INT books using periph
\zglot|L\*
\zgetperiph|side="L" id="abbrlist"\*
\pagebreak
\zglot|R\*
\zgetperiph|side="R" id="abbrlist"\*
\rem The next line never gets removed in diglots
\zglot|\*

\ip